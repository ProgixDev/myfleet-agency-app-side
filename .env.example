# ──────────────────────────────────────────────────────────────────────────
# Expo public env vars
# These are inlined into the JS bundle at build time. Do NOT put secrets
# that must stay private here — anything prefixed with EXPO_PUBLIC_ is
# readable in the shipped app.
# ──────────────────────────────────────────────────────────────────────────

# Mapbox public access token used by src/services/mapsService.ts for:
#   - Geocoding API v6       (address → lat/lng)
#   - Directions API v5      (driving distance between two points)
#   - Static Images API      (preview thumbnail on the agency screen)
#
# Use the PUBLIC token (starts with `pk.`). Never place a secret token
# (starts with `sk.`) here — it would leak in the app bundle. Restrict the
# public token in the Mapbox dashboard to the 3 scopes above and to your
# app's URL/bundle IDs.
EXPO_PUBLIC_MAPBOX_TOKEN=

# Better Auth endpoint (Nest global prefix + auth controller path)
# Example local value: http://localhost:4000
EXPO_PUBLIC_API_URL=http://localhost:4000

# Web admin (billing) base URL. AI credits and plan upgrades are purchased
# on the web admin, not in the app — the mobile apps deep-link to it for
# billing. Defaults to the production deployment when unset.
EXPO_PUBLIC_WEB_ADMIN_URL=https://web-admin-mu-nine.vercel.app

# Supabase
# Your Supabase project URL and anon (publishable) key.
# Get these from your Supabase dashboard → Settings → API.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Stripe — publishable key only (pk_test_… / pk_live_…). The agency app
# uses this to confirm deposit auth holds at handover via the Payment
# Sheet (POST /bookings/:id/deposit/authorize-intent on the server).
# Never put STRIPE_SECRET_KEY or STRIPE_WEBHOOK_SECRET here — those are
# server-only.
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# iOS only — required by Apple Pay if you enable it in the Payment Sheet.
EXPO_PUBLIC_STRIPE_MERCHANT_IDENTIFIER=
